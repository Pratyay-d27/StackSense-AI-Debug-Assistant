{
  "name": "stacksense",
  "displayName": "StackSense",
  "description": "AI Debug + Chat Assistant inside VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stacksense.open",
        "title": "Open StackSense"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "marked": "^18.0.2"
  }
}

